# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://thronos:password@localhost:5432/thronos_build

# Redis (Bull queue)
REDIS_URL=redis://localhost:6379

# Worker
WORKER_CONCURRENCY=2

# GitHub (for iOS builds via GitHub Actions)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_BUILD_REPO=your-org/ios-build-runner

# AWS S3 (artifact storage fallback)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=thronos-build-artifacts
AWS_S3_REGION=eu-central-1

# Local disk storage (mount a volume here, e.g., 50GB)
LOCAL_STORAGE_PATH=
# Public URL for artifact downloads (used with local storage)
APP_URL=

# IPFS (primary artifact storage)
IPFS_API_URL=http://localhost:5001

# Android SDK
ANDROID_HOME=/opt/android-sdk

# Thronos V3.6 Blockchain
THRONOS_NODE_URL=https://node.thronos.io
TREASURY_THR_ADDRESS=THR_YOUR_TREASURY_ADDRESS_HERE
TREASURY_AUTH_SECRET=your_treasury_auth_secret_for_refunds

# ─── Native THR pricing (accounting currency) ─────────────────────────
# Use the _THR suffix variants; plain names kept for backward compatibility.
PRICE_ANDROID_APK_THR=10
PRICE_ANDROID_AAB_THR=10
PRICE_IOS_IPA_THR=50
PRICE_BOTH_DISCOUNT_THR=5

# Legacy aliases (still supported)
PRICE_ANDROID_APK=10
PRICE_ANDROID_AAB=10
PRICE_IOS_IPA=50

# ─── External minimum floor prices ────────────────────────────────────
# BTC floors (in BTC)
MIN_BTC_ANDROID_APK=0.001
MIN_BTC_ANDROID_AAB=0.0015
MIN_BTC_IOS_IPA=0.003
MIN_BTC_BOTH=0.004

# Stablecoin / USD floors (in USD, applies to USDT and USDC)
MIN_USD_ANDROID_APK=100
MIN_USD_ANDROID_AAB=150
MIN_USD_IOS_IPA=300
MIN_USD_BOTH=400

# ─── Exchange rate references (optional, for ETH/BNB/BTC conversion) ──
# If ETH_USD_REFERENCE or BNB_USD_REFERENCE are not set, those payment
# methods will return 400 — set them to enable ETH/BNB quoting.
THR_USD_REFERENCE=0.05
THR_BTC_RATE=
BTC_USD_REFERENCE=
ETH_USD_REFERENCE=
BNB_USD_REFERENCE=
SOL_USD_REFERENCE=

# ─── Feature flags ─────────────────────────────────────────────────────
# Set to true only when a macOS build host and signing config are ready.
IOS_ENABLED=false

# Internal free builds (comma-separated allowlist)
BUILDER_ALLOW_INTERNAL_FREE_BUILDS=false
BUILDER_INTERNAL_FREE_WALLETS=
